# ============================================================
# Moabom Prototype — .env 템플릿
# ============================================================
# 이 파일은 git에 커밋됩니다. 실제 키 값을 절대 넣지 마세요.
# 사용법: `cp .env.example .env` 후 실제 값으로 채우기.
# (.env 는 .gitignore 로 커밋 제외)
#
# [필수] 표시는 해당 기능을 쓰려면 반드시 채워야 하는 값.
# 나머지는 미설정 시 코드 기본값(주석의 default) 사용.
# ------------------------------------------------------------

# --- Database (PostgreSQL) [필수] ---
# 형식: postgresql://<user>:<password>@<host>:<port>/<dbname>
# 로컬 docker-compose 사용 시 아래 기본값 그대로 사용 가능.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/techdb

# --- YouTube Data API v3 [필수] ---
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# --- RunYourAI — 통합 LLM provider [필수] ---
# 댓글 분류·감성·영상선택·보고서 등 모든 LLM 호출 단일 게이트웨이.
# 모델은 provider/model 형식 ("openai/gpt-4.1-...", "claude/...", "gemini/...").
RUNYOURAI_API_KEY=
RUNYOURAI_BASE_URL=https://api.runyour.ai/v1
RUNYOURAI_MODEL=openai/gpt-4.1-2025-04-14

# --- Serper (serper.dev) — Phase 3 제품 이미지 Google Images 검색 ---
# PRODUCT_IMAGE_ENABLED=1 일 때 [필수]. 미설정 시 이미지 없이 안전 퇴화.
# https://serper.dev 대시보드에서 발급.
SERPER_API_KEY=
# default: https://google.serper.dev/images
SERPER_IMAGES_ENDPOINT=

# --- Groq LLM (comment_filtering_agent 대체 경로, 조건부) ---
# 미설정 시 Groq 분류·감성 경로 비활성 (RunYourAI 경로만 사용).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Hugging Face (선택) ---
HF_TOKEN=

# --- FastAPI 서버 ---
# default: 8000
PORT=8000

# --- Phase 1: 보고서 4종 다중 LLM 검증 ---
# default: on. 0/false/no/off → 비활성.
REPORT_VERIFICATION_ENABLED=1

# --- Phase 2-a: 보고서 ④ 입력 확장 (영상별 ①②③ 종합) ---
# default: on. off 면 Phase 2-a 이전 동작.
REPORT4_INPUT_EXPANSION=1

# --- Phase 2-b: 보고서 ④ 생성 RAG (의미 검색·재정렬) ---
# default: on. off 면 truncate(절삭) 동작. 실패 시 절삭으로 안전 퇴화.
REPORT4_RAG=1
# RunYourAI 게이트웨이는 provider/model 형식 요구. 변경 시 재인덱싱 필요.
# default: openai/text-embedding-3-small
REPORT4_RAG_EMBED_MODEL=openai/text-embedding-3-small
# RAG 전용 SQLite 벡터 저장소 경로. default: <repo>/.rag/rag_vectors.sqlite3
REPORT4_RAG_DB_PATH=
# 검색 쿼리당 상위 청크 수. default: 8
REPORT4_RAG_TOP_K=8

# --- Phase 3: 제품 이미지 검색·검증·저장 ---
# default: on. off 면 이미지 수집 통째 skip (긴급/비용 통제).
PRODUCT_IMAGE_ENABLED=1
# 검색 후보 수. default: 10
PRODUCT_IMAGE_SEARCH_NUM=10
# 후보 다운로드 타임아웃(초). default: 12
PRODUCT_IMAGE_DL_TIMEOUT=12
# 이미지 1장 용량 상한(byte). default: 8388608 (8MB)
PRODUCT_IMAGE_MAX_BYTES=8388608
# 썸네일/아이콘 배제 최소 변(px). default: 300
PRODUCT_IMAGE_MIN_PX=300
# 비전 검증 모델. default: RUNYOURAI_MODEL 값
PRODUCT_IMAGE_VISION_MODEL=
# 검색 쿼리 접미사. default: "공식 제품 사진"
PRODUCT_IMAGE_QUERY_SUFFIX=

# --- /admin 대시보드 · 사용량 추적 (선택) ---
# /admin 접근 보호 토큰. 미설정 시 대시보드 비보호/비활성.
ADMIN_TOKEN=
# GA4 측정 ID (예: G-XXXXXXX). 미설정 시 GA 태그 미주입.
GA_MEASUREMENT_ID=
# 제품 목록 노출 여부. default: off 계열
SHOW_PRODUCT_LIST=

# --- 자막 수집 쿠키 (datacenter IP 봇 차단 우회) ---
# 둘 중 하나. PATH=쿠키 파일 경로 / B64=쿠키 파일 base64 인코딩 문자열.
YT_COOKIES_PATH=
YT_COOKIES_B64=

# --- 홈서버 자막 fetch worker 연동 (선택) ---
# 메인 앱이 호출할 worker URL + 인증 토큰. 미설정 시 worker 미사용.
YOUTUBE_FETCH_WORKER_URL=
YOUTUBE_FETCH_WORKER_TOKEN=
# worker 측 자체 인증 토큰 (services/fetch_worker 기동 시).
FETCH_WORKER_TOKEN=
